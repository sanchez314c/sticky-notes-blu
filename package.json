{
  "name": "stickynotes",
  "version": "1.0.0",
  "description": "A simple clean modern dark-mode StickyNotes app for macOS",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "start:secure": "electron src/main/main-secure.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "security:test": "electron security-test-comprehensive.js",
    "security:audit": "npm audit && node -e \"console.log('Security audit completed')\"",
    "dist": "electron-builder --mac --win --linux",
    "dist:secure": "npm run security:test && electron-builder --mac --win --linux",
    "dist:current": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:win:msi": "electron-builder --win --config.win.target=msi",
    "dist:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "sticky",
    "notes",
    "macos",
    "electron",
    "desktop"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/stickynotes",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "electron": "27.3.11",
    "electron-builder": "^25.1.8",
    "electron-mock-ipc": "^0.3.12",
    "jest": "^30.1.3"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-machine-id": "^1.1.12"
  },
  "build": {
    "appId": "com.yourcompany.stickynotes",
    "productName": "StickyNotes",
    "copyright": "Copyright © 2024 ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.code-workspace",
      "!LICENSE.md",
      "!package-lock.json",
      "!yarn.lock",
      "!pnpm-lock.yaml",
      "!.git",
      "!.vscode",
      "!node_modules/.cache",
      "!dist",
      "!scripts"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icons/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "win": {
      "icon": "assets/icons/icon-256.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StickyNotes"
    },
    "linux": {
      "icon": "assets/icons",
      "category": "Utility",
      "maintainer": "Your Name <your.email@example.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/backups/"
    ]
  }
}
