{
  "name": "Cross-Platform Desktop Application Stack",
  "version": "1.0.0",
  "description": "Optimized technology stack for cross-platform desktop applications",
  "framework": "Electron",
  "frontend": {
    "framework": "React",
    "version": "^18.2.0",
    "language": "TypeScript",
    "bundler": "Webpack",
    "styling": "CSS Modules + Styled Components",
    "state_management": "Redux Toolkit",
    "ui_components": "Ant Design"
  },
  "main_process": {
    "language": "TypeScript",
    "security": {
      "context_isolation": true,
      "node_integration": false,
      "sandbox": true,
      "preload_scripts": true
    },
    "auto_updater": "electron-updater",
    "crash_reporting": "electron-crash-reporter"
  },
  "build_system": {
    "bundler": "electron-builder", 
    "platforms": ["mac", "windows", "linux"],
    "signing": {
      "mac": "Developer ID Application",
      "windows": "Code Signing Certificate"
    },
    "distribution": {
      "mac": "DMG + Mac App Store",
      "windows": "NSIS Installer + Microsoft Store",
      "linux": "AppImage + Snap"
    }
  },
  "testing": {
    "unit": "Jest",
    "integration": "Spectron",
    "e2e": "Playwright",
    "visual": "Percy"
  },
  "development": {
    "hot_reload": "electron-reload",
    "debugging": "Chrome DevTools + VS Code",
    "performance": "electron-performance-toolkit"
  },
  "deployment": {
    "ci_cd": "GitHub Actions",
    "auto_updates": "electron-updater + GitHub Releases",
    "crash_reporting": "Sentry",
    "analytics": "Google Analytics 4"
  }
}
