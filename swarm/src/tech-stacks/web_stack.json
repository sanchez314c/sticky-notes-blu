{
  "name": "Modern Web Application Stack",
  "version": "1.0.0",
  "description": "Optimized technology stack for modern web applications",
  "frontend": {
    "framework": "React",
    "version": "^18.2.0",
    "language": "TypeScript",
    "bundler": "Vite",
    "styling": "Tailwind CSS",
    "state_management": "Zustand",
    "routing": "React Router",
    "testing": {
      "unit": "Jest + Testing Library",
      "e2e": "Playwright",
      "visual": "Chromatic"
    }
  },
  "backend": {
    "runtime": "Node.js",
    "framework": "Express.js",
    "language": "TypeScript", 
    "database": {
      "primary": "PostgreSQL",
      "orm": "Prisma",
      "cache": "Redis"
    },
    "authentication": "JWT + bcrypt",
    "validation": "Zod",
    "testing": {
      "unit": "Jest",
      "integration": "Supertest",
      "load": "Artillery"
    }
  },
  "deployment": {
    "containerization": "Docker",
    "orchestration": "Docker Compose",
    "cloud": "Vercel (Frontend) + Railway (Backend)",
    "ci_cd": "GitHub Actions",
    "monitoring": "Sentry + LogRocket"
  },
  "development": {
    "version_control": "Git",
    "code_quality": {
      "linting": "ESLint + Prettier",
      "type_checking": "TypeScript",
      "pre_commit": "Husky + lint-staged"
    },
    "package_manager": "npm"
  }
}
